---
---
<nav id="main-nav">
  <a href="/" class="logo">Adam Navarro</a>
  <div class="links">
    <a href="#work">Work</a>
    <a href="#about">About</a>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <span class="toggle-track">
        <span class="toggle-dot"></span>
      </span>
    </button>
    <a href="mailto:navarro.adamadrian@gmail.com" class="cta">Get in touch</a>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem var(--pad);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  nav.scrolled {
    background: var(--bg);
    border-bottom-color: var(--border);
  }

  .logo {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.3s forwards;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 2rem;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.5s forwards;
  }

  .links a {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .links a:hover { color: var(--text); }

  .cta {
    color: var(--text) !important;
    border: 1px solid var(--border);
    padding: 0.45rem 1.1rem;
    border-radius: 100px;
    background: transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s !important;
  }

  .cta:hover {
    background: var(--text) !important;
    color: var(--bg) !important;
    border-color: var(--text);
  }

  /* Theme toggle */
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .toggle-track {
    display: flex;
    align-items: center;
    width: 32px;
    height: 18px;
    background: var(--border);
    border-radius: 100px;
    border: 1px solid var(--border);
    position: relative;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .toggle-dot {
    position: absolute;
    left: 3px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--muted);
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), background 0.3s ease;
  }

  :global(.dark) .toggle-track {
    background: rgba(240,237,232,0.15);
    border-color: rgba(240,237,232,0.15);
  }

  :global(.dark) .toggle-dot {
    transform: translateX(14px);
    background: var(--text);
  }

  @media (max-width: 560px) {
    .links a:not(.cta) { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('theme-toggle');
  const root = document.documentElement;

  // Persist preference
  const saved = localStorage.getItem('theme');
  if (saved === 'dark') root.classList.add('dark');

  const onScroll = () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const isDark = root.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
