---
const projects = [
  {
    id: "01",
    title: "Central",
    industry: "Web3 · Blockchain",
    tags: ["Branding", "Landing Page", "UI/UX Design", "Marketing Materials", "Motion Design"],
    image: "https://framerusercontent.com/images/wd718ynnDuF2IjnLpFikQXB0R4c.png",
    link: "/work/central",
  },
  {
    id: "02",
    title: "Payeah",
    industry: "Fintech · Payments",
    tags: ["Branding", "Landing Page", "UI/UX Design"],
    image: "https://framerusercontent.com/images/HHKuYQ9B54izb0GUbKyV1b0bCk0.png",
    link: "/work/payeah",
  },
  {
    id: "03",
    title: "xSpend",
    industry: "Crypto · Payments",
    tags: ["Branding", "Landing Page", "UI/UX Design", "Marketing Materials"],
    image: "https://framerusercontent.com/images/93IOOrnHHa9iSfaEMtTEI9qunNw.png",
    link: "/work/xspend",
  },
  {
    id: "04",
    title: "Studyabroad.com",
    industry: "EdTech · Education",
    tags: ["Branding", "Landing Page", "Marketing Materials"],
    image: "https://framerusercontent.com/images/rZwBno1huNQLveqhxMpqc5tN0.png",
    link: "/work/studyabroad",
  },
  {
    id: "05",
    title: "GetX",
    industry: "Web3 · E-commerce",
    tags: ["Branding", "Landing Page", "UI/UX Design", "Marketing Materials"],
    image: "https://framerusercontent.com/images/8ZkjKSfEsdh6sQjYbDyUcH5zK4.png",
    link: "/work/getx",
  },
  {
    id: "06",
    title: "xMerchant",
    industry: "Web3 · Payments",
    tags: ["Landing Page", "UI/UX Design", "3D Illustrations"],
    image: "https://framerusercontent.com/images/cQhXAx7fK0dvItZZkwdZ8QWzGM.png",
    link: "/work/xmerchant",
  },
];
---

<section id="work" class="work">
  <div class="work-inner">
    <div class="work-header">
      <p class="section-label">Selected Work</p>
    </div>

    <div class="projects">
      {projects.map((p) => (
        <a
          href={p.link}
          target={p.link.startsWith('/') ? '_self' : '_blank'}
          rel={p.link.startsWith('/') ? undefined : 'noopener'}
          class="project"
          data-reveal
        >
          <div class="project-img-wrap">
            <img
              src={p.image}
              alt={p.title}
              loading="lazy"
              decoding="async"
              width="1674"
              height="900"
            />
            <div class="project-overlay">
              <span class="view-label">View Project ↗</span>
            </div>
          </div>
          <div class="project-meta">
            <div class="project-left">
              <span class="project-id">{p.id}</span>
              <div class="project-info">
                <h3 class="project-title">{p.title}</h3>
                <p class="project-industry">{p.industry}</p>
              </div>
            </div>
            <div class="project-tags">
              {p.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work {
    padding: 8rem var(--pad) 6rem;
  }

  .work-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .work-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 3.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .view-all {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }
  .view-all:hover { color: var(--text); }

  .projects {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
  }

  .project:nth-child(even) {
    padding-left: clamp(0px, 8vw, 120px);
  }

  .project {
    display: block;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
                transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }

  .project.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-img-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 16 / 9;
    background: #e8e6e0;
  }

  .project-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
  }

  .project:hover .project-img-wrap img {
    transform: scale(1.03);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(14,14,14,0.45);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .project:hover .project-overlay { opacity: 1; }

  .view-label {
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.5);
    padding: 0.6rem 1.4rem;
    border-radius: 100px;
  }

  .project-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 1.25rem;
    flex-wrap: wrap;
  }

  .project-left {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-id {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--muted);
    margin-top: 0.25rem;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-title {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .project-industry {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
    max-width: 55%;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.22rem 0.65rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .project:nth-child(even) { padding-left: 0; }
    .project-meta { flex-direction: column; gap: 1rem; }
    .project-tags { justify-content: flex-start; max-width: 100%; }
  }
</style>

<script>
  const items = document.querySelectorAll('[data-reveal]');
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  items.forEach((el) => io.observe(el));
</script>
