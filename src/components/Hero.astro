---
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-text">
        <p class="eyebrow">UI/UX Designer · 8+ Years</p>
        <div class="hero-photo-wrap">
          <img
            src="/adam-portrait.jpeg"
            alt="Adam Navarro"
            class="hero-photo"
            width="800"
            height="800"
          />
        </div>
        <h1 class="name">
          <span class="name-first">Adam</span>
          <span class="name-last">Navarro.</span>
        </h1>
        <p class="bio">
          Shaping digital products across fintech, insurance,
          marketplaces, and Web3. I craft intuitive user flows,
          scalable design systems, and cohesive brand identities —
          blending strong design craft with a foundation in software development.
        </p>
        <div class="hero-links">
          <a href="https://dribbble.com/adamnavarro" target="_blank" rel="noopener">Dribbble ↗</a>
          <a href="https://www.linkedin.com/in/navarroadamadrian/" target="_blank" rel="noopener">LinkedIn ↗</a>
          <a href="https://unsplash.com/@adamnavarro_" target="_blank" rel="noopener">Unsplash ↗</a>
          <a
            href="/adam-navarro-cv.pdf" download="Adam-Navarro-CV.pdf"
            target="_blank" rel="noopener"
            class="cv-btn"
          >Download CV</a>
        </div>
      </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(5rem, 12vh, 8rem) var(--pad) clamp(3rem, 8vh, 6rem);
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero-content {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
  }

  .hero-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero-photo-wrap {
    width: clamp(72px, 8vw, 100px);
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.16,1,0.3,1) 0.05s forwards;
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(15%);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.1s forwards;
  }

  .name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    display: flex;
    flex-direction: column;
  }

  .name-first {
    font-weight: 400;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.16,1,0.3,1) 0.2s forwards;
  }

  .name-last {
    font-weight: 300;
    letter-spacing: -0.03em;
    opacity: 0;
    animation: slideUp 1s cubic-bezier(0.16,1,0.3,1) 0.34s forwards;
  }

  .bio {
    max-width: 500px;
    font-size: clamp(0.92rem, 1.4vw, 1rem);
    color: var(--muted);
    line-height: 1.8;
    opacity: 0;
    animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s forwards;
  }

  .hero-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem 1.75rem;
    opacity: 0;
    animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.62s forwards;
  }

  .hero-links a {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .hero-links a:hover { color: var(--text); }

  .cv-btn {
    color: var(--text) !important;
    border: 1px solid var(--border);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    transition: background 0.2s, color 0.2s !important;
  }

  .cv-btn:hover {
    background: var(--text) !important;
    color: var(--bg) !important;
  }

  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
    max-width: var(--max-w);
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    animation: fadeIn 1s ease 1.1s forwards;
  }

  .scroll-hint span {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .line {
    width: 56px;
    height: 1px;
    background: var(--border);
    overflow: hidden;
    position: relative;
  }

  .line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: var(--text);
    animation: sweep 2s ease 1.3s infinite;
  }

  @keyframes sweep {
    0%   { left: -100%; }
    50%  { left: 0%; }
    100% { left: 100%; }
  }

  @media (max-width: 768px) {
    .hero-content { gap: 2rem; }
    .hero-photo-wrap { width: clamp(56px, 12vw, 72px); }
  }
</style>
