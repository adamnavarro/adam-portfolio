---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const project = {
  title: "Central",
  industry: "Web3 · Blockchain",
  tags: ["Branding", "Landing Page", "UI/UX Design", "Marketing Materials", "Motion Design"],
  overview: "Central needed a brand identity and digital presence that communicated trust, speed, and institutional credibility — without losing the boldness of a next-generation blockchain product. The challenge was balancing regulatory seriousness with the visual language of Web3.",
  sections: [
    {
      label: "Landing Page",
      images: [
        { src: "/images/central-landing-01.png", alt: "Central landing page hero — desktop and mobile" },
        { src: "/images/central-landing-02.png", alt: "Central landing page — Built to Settle Money section" },
        { src: "/images/central-landing-03.png", alt: "Central landing page — FX Perps section" },
      ]
    },
    {
      label: "Branding",
      images: [
        { src: "/images/central-branding.png", alt: "Central brand identity — logo exploration and color palette" },
      ]
    },
    {
      label: "Motion Design",
      images: [
        { src: "/images/central-motion-design.png", alt: "Central motion design — storyboard and animation frames" },
      ],
      videoLink: "https://drive.google.com/file/d/1GMWLFthKlBMtJ4FQbXxSS28Ai1VIckyB/view?usp=sharing",
      videoLabel: "Watch Intro Animation ↗"
    },
    {
      label: "Marketing Materials",
      images: [
        { src: "/images/central-marketing-materials.png", alt: "Central marketing materials — social cards" },
      ]
    },
    {
      label: "2D Illustrations",
      images: [
        { src: "/images/central-illustrations.png", alt: "Central 2D illustrations" },
      ]
    },
  ],
  prev: { title: "xMerchant", slug: "xmerchant" },
  next: { title: "Payeah", slug: "payeah" }
};
---

<Layout title={`${project.title} — Adam Navarro`} description={project.overview}>
  <Nav />
  <main class="case-study">
    <div class="container">

      <!-- Back -->
      <a href="/#work" class="back-link">← Back to works</a>

      <!-- Header -->
      <header class="project-header">
        <div class="header-left">
          <h1 class="project-title">{project.title}</h1>
          <p class="project-industry">{project.industry}</p>
        </div>
        <div class="project-tags">
          {project.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <!-- Overview -->
      <div class="overview">
        <p class="overview-label">Overview</p>
        <p class="overview-text">{project.overview}</p>
      </div>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Sections -->
      {project.sections.map(section => (
        <section class="work-section">
          <div class="section-header">
            <p class="section-label">{section.label}</p>
            {section.videoLink && (
              <a href={section.videoLink} target="_blank" rel="noopener" class="video-link">
                {section.videoLabel}
              </a>
            )}
          </div>
          <div class={`images-grid images-${section.images.length}`}>
            {section.images.map(img => (
              <div class="image-wrap">
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ))}
          </div>
        </section>
      ))}

      <!-- Project navigation -->
      <nav class="project-nav">
        <div class="project-nav-item">
          {project.prev && (
            <a href={`/work/${project.prev.slug}`} class="nav-project prev">
              <span class="nav-direction">← Previous</span>
              <span class="nav-title">{project.prev.title}</span>
            </a>
          )}
        </div>
        <div class="project-nav-item">
          {project.next && (
            <a href={`/work/${project.next.slug}`} class="nav-project next">
              <span class="nav-direction">Next →</span>
              <span class="nav-title">{project.next.title}</span>
            </a>
          )}
        </div>
      </nav>

    </div>
  </main>
</Layout>

<style>
  .case-study {
    padding-top: clamp(5rem, 12vh, 8rem);
    padding-bottom: 6rem;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--pad);
  }

  /* Back link */
  .back-link {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 3rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--text); }

  /* Header */
  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .project-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .project-industry {
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 400;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
    max-width: 50%;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  /* Overview */
  .overview {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    align-items: start;
  }

  .overview-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 0.2rem;
  }

  .overview-text {
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    line-height: 1.8;
    color: var(--muted);
    max-width: 680px;
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 4rem;
  }

  /* Work sections */
  .work-section {
    margin-bottom: 5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .video-link {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    transition: background 0.2s, color 0.2s;
  }

  .video-link:hover {
    background: var(--text);
    color: var(--bg);
  }

  /* Image grids */
  .images-grid {
    display: grid;
    gap: 1rem;
  }

  .images-1 { grid-template-columns: 1fr; }
  .images-2 { grid-template-columns: 1fr 1fr; }
  .images-3 { grid-template-columns: 1fr; }

  .image-wrap {
    overflow: hidden;
    border-radius: 4px;
    background: #e8e6e0;
  }

  .image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
  }

  .image-wrap:hover img {
    transform: scale(1.02);
  }

  /* For 3 images — first one full width, next two side by side */
  .images-3 .image-wrap:first-child {
    grid-column: 1 / -1;
  }

  .images-3 {
    grid-template-columns: 1fr 1fr;
  }

  .images-3 .image-wrap:first-child {
    grid-column: 1 / -1;
  }

  /* Project navigation */
  .project-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }

  .project-nav-item {
    flex: 1;
  }

  .project-nav-item:last-child {
    text-align: right;
  }

  .nav-project {
    display: inline-flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: opacity 0.2s;
  }

  .nav-project:hover { opacity: 0.6; }

  .nav-direction {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .nav-title {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .project-header { flex-direction: column; }
    .project-tags { justify-content: flex-start; max-width: 100%; }
    .overview { grid-template-columns: 1fr; gap: 0.75rem; }
    .images-2 { grid-template-columns: 1fr; }
    .images-3 { grid-template-columns: 1fr; }
    .images-3 .image-wrap:first-child { grid-column: 1; }
  }
</style>
